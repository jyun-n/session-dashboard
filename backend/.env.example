NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/session_dashboard?schema=public

# JWT_SECRET: 최소 32자 이상의 강한 랜덤 값. placeholder("change-me" 등)는 거부됨.
# 생성: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-strong-random-value-min-32-chars
JWT_EXPIRES_IN=15m

CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=info
DELETE_SECRET=*

# EMR API
EMR_BASE_URL=http://emr124.cauhs.or.kr/cmcnu/.live
EMR_INST_CD=124
