NODE_ENV=development
PORT=4000

# DB 접속 문자열. 비밀번호에 @ ! 등 특수문자가 있으면 URL 인코딩 필요 (@ → %40)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/session_dashboard?schema=public

# JWT_SECRET: 최소 32자 이상의 강한 랜덤 값. placeholder("change-me", "dashboard-jwt" 등)는 거부됨.
# 생성: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-strong-random-value-min-32-chars
JWT_EXPIRES_IN=15m

# 운영에서는 와일드카드(*) 절대 금지. 정확한 도메인 명시. 콤마로 여러 개 허용 가능.
# 예: https://dashboard.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=info

# 계정 탈퇴(soft delete) 시 관리자 확인용 시크릿. 16자 이상의 강한 랜덤 값 권장.
# 생성: node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
DELETE_SECRET=replace-with-strong-random-value

# 외부 EMR API. 운영 환경에서는 운영 EMR 주소로 변경.
EMR_BASE_URL=http://emr124.cauhs.or.kr/cmcnu/.live
EMR_INST_CD=124

# ─────────────────────────────────────────────────────────────────
# 시드 스크립트 (1회성) — 운영에서 초기 관리자 계정 생성 시에만 사용.
# .env에 둘 필요 없으며, 시드 실행 시 inline으로 주입:
#   Linux/macOS:  SEED_ADMIN_PASSWORD='Strong@Pass2026!' npx tsx src/scripts/seed.ts
#   PowerShell :  $env:SEED_ADMIN_PASSWORD="..."; npx tsx src/scripts/seed.ts
# 선택: SEED_ADMIN_LOGIN_ID (기본 admin), SEED_ADMIN_EMP_NO (기본 00000)
# 시드 직후 로그인하여 비밀번호 즉시 변경 필수. history -c 로 명령 기록도 비울 것.
# ─────────────────────────────────────────────────────────────────
