generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model Account {
  id           String    @id @default(cuid())
  empNo        String    @unique
  dept         String
  position     String
  name         String
  loginId      String    @unique
  passwordHash String
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  loginLogs    LoginLog[]

  @@map("accounts")
}

model LoginLog {
  id        String   @id @default(cuid())
  accountId String
  loginAt   DateTime @default(now())
  ipAddress String?
  userAgent String?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, loginAt(sort: Desc)])
  @@map("login_logs")
}

// DRPMA00100 - 외래진료 환자별 진료정보
model RawPatientStats {
  id          Int      @id @default(autoincrement())
  statDate    DateTime @db.Date
  doctorId    String
  doctorName  String
  deptCd      String
  deptName    String
  fsexamFlag  String
  avgOrdTime  String?
  avgWaitTime String?
  avgOrdMin   Decimal? @db.Decimal(10, 2)
  avgWaitMin  Decimal? @db.Decimal(10, 2)
  patCnt      Int      @default(0)
  collectedAt DateTime @default(now())

  @@unique([statDate, doctorId, deptCd, fsexamFlag])
  @@index([statDate, deptCd])
  @@map("raw_patient_stats")
}

// DRPMA00200 - 외래세션정보
model RawSession {
  id               Int      @id @default(autoincrement())
  statDate         DateTime @db.Date        // basedd
  deptCd           String
  deptName         String
  doctorId         String
  doctorName       String
  planSession      Int      @default(0)
  realSession      Int      @default(0)
  totalExamCap     Int      @default(0)     // totalexamcap (fstExamCap + reExamCap 통합)
  closeReason      String?                  // ordendresn — 진료마감사유
  closeRequestTime String?                  // lastupdtdt — 진료마감시간 (YYYYMMDDHHMMSS 14자리)
  collectedAt      DateTime @default(now())

  @@unique([statDate, doctorId, deptCd])
  @@index([statDate, deptCd])
  @@map("raw_sessions")
}

// DRPMA00100 (srchflag=T) - 교수별 진료 시작/종료시간
// 호출 단위는 (날짜, 진료과, 진료의) 필수. 응답은 환자별 진료 이벤트 row 다수 →
// 수집 단계에서 MIN(ordstartdt), MAX(dracptdt)로 합쳐 (날짜, 의사, 과) 단위 1행 저장.
model RawDoctorTime {
  id                 Int      @id @default(autoincrement())
  statDate           DateTime @db.Date
  doctorId           String
  doctorName         String
  deptCd             String
  deptName           String
  treatmentStartTime String?  // MIN(ordstartdt) — YYYYMMDDHHMMSS 14자리
  treatmentEndTime   String?  // MAX(dracptdt)  — YYYYMMDDHHMMSS 14자리
  collectedAt        DateTime @default(now())

  @@unique([statDate, doctorId, deptCd])
  @@index([statDate, deptCd])
  @@map("raw_doctor_times")
}

// 교수별 집계
model DailyStatsByDoctor {
  id                 Int      @id @default(autoincrement())
  statDate           DateTime @db.Date
  deptCd             String
  deptName           String
  doctorId           String
  doctorName         String

  // 세션 (DRPMA00200)
  planSession        Int?
  realSession        Int?
  sessionUtilization Decimal? @db.Decimal(7, 2)
  totalExamCap       Int?                        // totalexamcap

  // 진료시간 / 대기시간
  avgOrdTime         String?
  avgWaitTime        String?
  avgOrdMin          Decimal? @db.Decimal(10, 2)
  avgWaitMin         Decimal? @db.Decimal(10, 2)

  // 초진 / 재진 / 전체 환자수 (4/5 제외)
  firstVisitCount    Int?     // F patcnt
  revisitCount       Int?     // R patcnt
  totalPatients      Int?     // D+S+R+F patcnt 합계

  // 예약현황 가동률 = totalPatients / totalExamCap × 100
  bookingRate        Decimal? @db.Decimal(7, 2)

  // 진료 시간 / 마감 정보 (YYYYMMDDHHMMSS 14자리 datetime)
  // - treatment*: DRPMA00100 srchflag=T (RawDoctorTime에서 머지, fsexamflag별 MIN/MAX)
  // - close*    : DRPMA00200 (RawSession에서 그대로 복사)
  treatmentStartTime String?
  treatmentEndTime   String?
  closeRequestTime   String?
  closeReason        String?

  aggregatedAt       DateTime @default(now())

  @@unique([statDate, doctorId, deptCd])
  @@index([statDate, deptCd])
  @@map("daily_stats_by_doctor")
}

// 진료과별 집계
model DailyStatsByDept {
  id                 Int      @id @default(autoincrement())
  statDate           DateTime @db.Date
  deptCd             String
  deptName           String

  // 세션
  planSession        Int?
  realSession        Int?
  sessionUtilization Decimal? @db.Decimal(7, 2)
  totalExamCap       Int?

  // 진료시간 / 대기시간
  avgOrdTime         String?
  avgWaitTime        String?

  // 초진 / 재진 / 전체 환자수
  firstVisitCount    Int?
  revisitCount       Int?
  totalPatients      Int?

  // 예약현황 가동률
  bookingRate        Decimal? @db.Decimal(7, 2)

  // 교수 수
  doctorCount        Int?

  aggregatedAt       DateTime @default(now())

  @@unique([statDate, deptCd])
  @@index([statDate, deptCd])
  @@map("daily_stats_by_dept")
}