generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model Account {
  id           String    @id @default(cuid())
  empNo        String    @unique
  dept         String
  position     String
  name         String
  loginId      String    @unique
  passwordHash String
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  loginLogs    LoginLog[]

  @@map("accounts")
}

model LoginLog {
  id        String   @id @default(cuid())
  accountId String
  loginAt   DateTime @default(now())
  ipAddress String?
  userAgent String?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, loginAt(sort: Desc)])
  @@map("login_logs")
}

// DRPMA00100 - 외래진료 환자별 진료정보
model RawPatientStats {
  id          Int      @id @default(autoincrement())
  statDate    DateTime @db.Date
  doctorId    String
  doctorName  String
  deptCd      String
  deptName    String
  fsexamFlag  String
  avgOrdTime  String?
  avgWaitTime String?
  avgOrdMin   Decimal? @db.Decimal(10, 2)
  avgWaitMin  Decimal? @db.Decimal(10, 2)
  patCnt      Int      @default(0)
  collectedAt DateTime @default(now())

  @@unique([statDate, doctorId, deptCd, fsexamFlag])
  @@index([statDate, deptCd])
  @@map("raw_patient_stats")
}

// DRPMA00200 - 외래세션정보
model RawSession {
  id            Int      @id @default(autoincrement())
  statDate      DateTime @db.Date        // basedd
  deptCd        String
  deptName      String
  doctorId      String
  doctorName    String
  planSession   Int      @default(0)
  realSession   Int      @default(0)
  totalExamCap  Int      @default(0)     // totalexamcap (fstExamCap + reExamCap 통합)
  collectedAt   DateTime @default(now())

  @@unique([statDate, doctorId, deptCd])
  @@index([statDate, deptCd])
  @@map("raw_sessions")
}

// 교수별 집계
model DailyStatsByDoctor {
  id                 Int      @id @default(autoincrement())
  statDate           DateTime @db.Date
  deptCd             String
  deptName           String
  doctorId           String
  doctorName         String

  // 세션 (DRPMA00200)
  planSession        Int?
  realSession        Int?
  sessionUtilization Decimal? @db.Decimal(7, 2)
  totalExamCap       Int?                        // totalexamcap

  // 진료시간 / 대기시간
  avgOrdTime         String?
  avgWaitTime        String?
  avgOrdMin          Decimal? @db.Decimal(10, 2)
  avgWaitMin         Decimal? @db.Decimal(10, 2)

  // 초진 / 재진 / 전체 환자수 (4/5 제외)
  firstVisitCount    Int?     // F patcnt
  revisitCount       Int?     // R patcnt
  totalPatients      Int?     // D+S+R+F patcnt 합계

  // 예약현황 가동률 = totalPatients / totalExamCap × 100
  bookingRate        Decimal? @db.Decimal(7, 2)

  aggregatedAt       DateTime @default(now())

  @@unique([statDate, doctorId, deptCd])
  @@index([statDate, deptCd])
  @@map("daily_stats_by_doctor")
}

// 진료과별 집계
model DailyStatsByDept {
  id                 Int      @id @default(autoincrement())
  statDate           DateTime @db.Date
  deptCd             String
  deptName           String

  // 세션
  planSession        Int?
  realSession        Int?
  sessionUtilization Decimal? @db.Decimal(7, 2)
  totalExamCap       Int?

  // 진료시간 / 대기시간
  avgOrdTime         String?
  avgWaitTime        String?

  // 초진 / 재진 / 전체 환자수
  firstVisitCount    Int?
  revisitCount       Int?
  totalPatients      Int?

  // 예약현황 가동률
  bookingRate        Decimal? @db.Decimal(7, 2)

  // 교수 수
  doctorCount        Int?

  aggregatedAt       DateTime @default(now())

  @@unique([statDate, deptCd])
  @@index([statDate, deptCd])
  @@map("daily_stats_by_dept")
}